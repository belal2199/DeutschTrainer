{
  "name": "deutsch-trainer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npx ng serve --port 4200 --proxy-config proxy.conf.json",
    "seed": "cd server && npm run seed",
    "seed:daily-life": "cd server && npm run seed:daily-life",
    "seed:all": "cd server && npm run seed:all",
    "build": "cd client && npx ng build && cd ../server && npx tsc",
    "start": "node server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
